{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "labels": [
    "dependencies"
  ],
  "timezone": "Europe/Dublin",
  "tekton": {
    "schedule": [
      "at any time"
    ],
    "automerge": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track repo SHAs in config.yaml",
      "managerFilePatterns": [
        "/^config\\.yaml$/"
      ],
      "matchStrings": [
        "url:\\s*https://github\\.com/(?<packageName>[^\\n]+?)\\n\\s*ref:\\s*(?<currentDigest>[a-f0-9]{40})\\s+#\\s*(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "{{{packageName}}}",
      "depTypeTemplate": "git-sha"
    },
    {
      "customType": "regex",
      "description": "Track catalog development SHA",
      "managerFilePatterns": [
        "/^config\\.yaml$/"
      ],
      "matchStrings": [
        "development:\\n\\s*branch:\\s*development\\n\\s*ref:\\s*(?<currentDigest>[a-f0-9]{40})\\s+#\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "konflux-ci/release-service-catalog",
      "packageNameTemplate": "https://github.com/konflux-ci/release-service-catalog",
      "datasourceTemplate": "git-refs",
      "depTypeTemplate": "catalog-development"
    },
    {
      "customType": "regex",
      "description": "Track catalog staging SHA",
      "managerFilePatterns": [
        "/^config\\.yaml$/"
      ],
      "matchStrings": [
        "staging:\\n\\s*branch:\\s*staging\\n\\s*ref:\\s*(?<currentDigest>[a-f0-9]{40})\\s+#\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "konflux-ci/release-service-catalog",
      "packageNameTemplate": "https://github.com/konflux-ci/release-service-catalog",
      "datasourceTemplate": "git-refs",
      "depTypeTemplate": "catalog-staging"
    },
    {
      "customType": "regex",
      "description": "Track catalog production SHA",
      "managerFilePatterns": [
        "/^config\\.yaml$/"
      ],
      "matchStrings": [
        "production:\\n\\s*branch:\\s*production\\n\\s*ref:\\s*(?<currentDigest>[a-f0-9]{40})\\s+#\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "konflux-ci/release-service-catalog",
      "packageNameTemplate": "https://github.com/konflux-ci/release-service-catalog",
      "datasourceTemplate": "git-refs",
      "depTypeTemplate": "catalog-production"
    }
  ],
  "packageRules": [
    {
      "description": "Config repo SHAs, daily, auto-merge when CI passes",
      "matchDepTypes": [
        "git-sha",
        "catalog-development",
        "catalog-staging",
        "catalog-production"
      ],
      "automerge": true,
      "schedule": [
        "before 8am every weekday"
      ],
      "groupName": "config-repo-shas"
    }
  ]
}
